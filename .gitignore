__pycache__/
*.py[cod]
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage.xml
htmlcov/
node_modules/
dist/
build/
*.log
.DS_Store
.idea/
.vscode/
minio-data/
postgres-data/
redis-data/

$GitIgnoreEntries = @(
    "",
    "# Runtime AI model cache",
    "data/models/",
    "",
    "# TypeScript incremental build cache",
    "*.tsbuildinfo"
)

foreach ($Entry in $GitIgnoreEntries) {
    if (
        $Entry -eq ""
        -or -not (
            Select-String `
                -Path .gitignore `
                -SimpleMatch `
                -Quiet `
                -Pattern $Entry `
                -ErrorAction SilentlyContinue
        )
    ) {
        Add-Content `
            -Path .gitignore `
            -Value $Entry
    }
}

@"

# Runtime AI model cache
data/models/

# TypeScript incremental build cache
*.tsbuildinfo
"@ | Add-Content .gitignore