PROJECT_NAME=InsightOps AI
ENVIRONMENT=development

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=5173

POSTGRES_DB=insightops
POSTGRES_USER=insightops
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://insightops:change_me@postgres:5432/insightops

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=insightops
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=insightops-documents
MINIO_SECURE=false

# Local embeddings and RAG
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_DIRECTORY=/app/data/models/fastembed

RAG_CHUNK_SIZE_CHARACTERS=1200
RAG_CHUNK_OVERLAP_CHARACTERS=200
RAG_DEFAULT_TOP_K=8
RAG_MAX_TOP_K=25

JWT_SECRET_KEY=insightops-local-development-secret-change-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

VITE_API_BASE_URL=http://localhost:8000/api/v1

DEMO_WORKSPACE_SLUG=insightops-insurance-demo
DEMO_ADMIN_EMAIL=admin@insightops.ai
DEMO_ADMIN_FULL_NAME=InsightOps Administrator
DEMO_ADMIN_PASSWORD=replace_with_a_secure_demo_password

# Safe SQL Agent
SQL_AGENT_MAX_ROWS=500
SQL_AGENT_MAX_SQL_LENGTH=20000
SQL_AGENT_STATEMENT_TIMEOUT_MS=5000